#!/usr/bin/env bash
# Zanuda CLI wrapper — auto-detects built vs source runtime.
# Handles npm link by following symlinks to the real script location.
set -euo pipefail

SELF="$0"
while [ -L "$SELF" ]; do
  TARGET="$(readlink "$SELF")"
  case "$TARGET" in
    /*) SELF="$TARGET" ;;
    *)  SELF="$(dirname "$SELF")/$TARGET" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ -f "$PROJECT_ROOT/dist/cli.js" ]; then
  exec node "$PROJECT_ROOT/dist/cli.js" "$@"
elif [ -f "$PROJECT_ROOT/src/cli.ts" ]; then
  exec npx --no-install tsx "$PROJECT_ROOT/src/cli.ts" "$@"
else
  echo "zanuda: cannot find dist/cli.js or src/cli.ts in $PROJECT_ROOT" >&2
  exit 1
fi
