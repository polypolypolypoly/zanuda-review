# ═══════════════════════════════════════════════════════════════════════
# Zanuda — environment configuration.
#
# Taxonomy:
#   .env      = secrets, endpoints, deployment plumbing, hardware constraints.
#               Things you set once per machine.
#   YAML      = everything semantic: provider, model, generation, context,
#               review behaviour, memory, access control, rate limits.
#               Defaults in config/default.yaml; override via ZANUDA_CONFIG
#               or per-repo .zanuda/config.yml.
#
# The only overlap is LLM_PROVIDER / LLM_MODEL — kept as convenience
# overrides for quick deployment. New settings follow the taxonomy:
# if it's a hardware constraint (like LLM_MAX_CONTEXT_TOKENS) → env.
# If it's a review behaviour choice → YAML.
# ═══════════════════════════════════════════════════════════════════════

# ── Platform ─────────────────────────────────────────────────────────
#   github | local
PLATFORM=github

# ── Secrets ──────────────────────────────────────────────────────────
# GitHub PAT (classic: repo scope, or fine-grained: Pull requests RW + Contents RO).
GITHUB_TOKEN=

# LLM API keys — only the selected provider's key is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ── Endpoints ────────────────────────────────────────────────────────
# Override for proxies, LM Studio, or self-hosted deployments.
# OPENAI_BASE_URL=http://localhost:1234/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434
# DEEPSEEK_BASE_URL=
# GEMINI_BASE_URL=

# ── Runtime tuning ───────────────────────────────────────────────────
POLL_INTERVAL_SECS=60
LOG_LEVEL=info
# Cap output tokens for local models that reject oversized max_tokens.
# Default 2048 is safe for most Ollama models. Set to 0 to use the
# config-level maxTokens directly (e.g. for newer models with 8K+ output).
OLLAMA_MAX_OUTPUT_TOKENS=2048

# ── Hardware constraints ─────────────────────────────────────────────
# Model context window size in tokens. When set, Zanuda trims the diff
# budget before the LLM call to avoid context-overflow errors. Useful for
# local models with small windows (e.g. 4096 for LM Studio). Unset = no
# limit (cloud models).
LLM_MAX_CONTEXT_TOKENS=

# ── YAML config overlay ──────────────────────────────────────────────
# Path to a YAML file with overrides for config/default.yaml. This is the
# recommended way to customise provider, model, generation, context, review
# behaviour, memory, access control, and rate limits. Example:
#   ZANUDA_CONFIG=~/.zanuda/config.yaml
ZANUDA_CONFIG=

# ── Legacy convenience overrides ─────────────────────────────────────
# These predate ZANUDA_CONFIG and override the corresponding YAML fields.
# Prefer ZANUDA_CONFIG for permanent setup; use these for quick experiments.
# Valid providers: anthropic | openai | openrouter | ollama | deepseek | gemini
LLM_PROVIDER=anthropic
LLM_MODEL=
