# ── GitHub bot account ───────────────────────────────────────────────
# Personal Access Token for the bot's GitHub account (classic: repo scope,
# or fine-grained: Pull requests RW + Contents RO on the target repos).
GITHUB_TOKEN=
# The bot account's login (username). Used to detect when *this* bot was
# the one added as a reviewer.
GITHUB_BOT_LOGIN=
# Shared secret configured on each repo's webhook (Settings → Webhooks).
# Used to verify webhook payload signatures.
GITHUB_WEBHOOK_SECRET=

# ── Server ───────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── LLM provider selection ───────────────────────────────────────────
# Which provider the model-agnostic layer should use:
#   anthropic | openai | openrouter | ollama
LLM_PROVIDER=anthropic
# Model id for the selected provider (overrides config/default.yaml).
LLM_MODEL=

# ── Provider credentials (only the selected one is required) ─────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Ollama runs locally and needs no key.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Path to the config file (optional; defaults to config/default.yaml).
REVIEW_HELPER_CONFIG=
