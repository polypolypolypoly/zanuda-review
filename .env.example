# ── Platform ─────────────────────────────────────────────────────────
# Which source control platform to use. Default: github.
# To add a new platform see src/platform/stub/connector.ts.
#   github | local | (your connector name here)
#   Use 'local' to review staged git changes without a GitHub account.
PLATFORM=github

# ── GitHub reviewer account ──────────────────────────────────────────
# Personal Access Token for the reviewer's GitHub account (classic: repo scope,
# or fine-grained: Pull requests RW + Contents RO on the target repos).
GITHUB_TOKEN=

# ── Poller ───────────────────────────────────────────────────────────
# How often to poll GitHub for new review requests (seconds). Default: 60.
POLL_INTERVAL_SECS=60

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── LLM provider selection ───────────────────────────────────────────
# Which provider the model-agnostic layer should use:
#   anthropic | openai | openrouter | ollama | deepseek
LLM_PROVIDER=anthropic
# Model id for the selected provider (overrides config/default.yaml).
LLM_MODEL=

# ── Provider credentials (only the selected one is required) ─────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Ollama runs locally and needs no key.
OLLAMA_BASE_URL=http://127.0.0.1:11434
DEEPSEEK_API_KEY=
# Override for self-hosted DeepSeek-compatible proxies (default: https://api.deepseek.com/v1).
# DEEPSEEK_BASE_URL=

# ── Misc ─────────────────────────────────────────────────────────────
# Path to a local config override file (optional; defaults to config/default.yaml).
ZANUDA_CONFIG=


