{
  "name": "zanuda-review",
  "version": "0.1.0",
  "private": true,
  "description": "Zanuda the Reviewer — a model-agnostic AI code reviewer for GitHub.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "zanuda": "./dist/cli.js"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "review": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "node --experimental-test-module-mocks --test --import tsx ./test/*.test.ts",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \".github/workflows/*.yml\" \"config/**/*.yaml\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \".github/workflows/*.yml\" \"config/**/*.yaml\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@octokit/rest": "^22.0.0",
    "dotenv": "^17.0.0",
    "openai": "^6.0.0",
    "pino": "^9.6.0",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.8.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0"
  }
}
